# LVV-PrepPal environment template — copy to `.env` and fill in real values.
# `.env` is git-ignored; this template is safe to commit (no secrets).

# ----- Database -----
DATABASE_URL=postgresql://user:password@localhost:5432/lvv

# ----- LLM provider selection -----
# auto = try Anthropic (Claude Fable 5) first, fall back to OpenAI.
# Other values: anthropic | openai
LLM_PROVIDER=auto

# ----- Anthropic (Claude Fable 5) — primary text AI -----
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-fable-5

# ----- OpenAI — fallback text AI + audio (text-to-speech) -----
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# ----- Auth -----
SECRET_KEY=change-me-to-a-long-random-secret

# ----- Vector store -----
CHROMA_PERSIST_DIR=./chroma_db
